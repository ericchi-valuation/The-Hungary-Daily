# Copy this file to .env and fill in your own credentials.
# Never commit the actual .env file to Git!

# ===== AI Script Generation (Google Gemini) =====
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===== (Optional) Premium TTS — ElevenLabs =====
# If set, the pipeline uses Hollywood-grade voice synthesis instead of Edge TTS.
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ===== Newsletter Distribution (Gmail SMTP) =====
# Your Gmail address (e.g. yourname@gmail.com)
GMAIL_ADDRESS=your_gmail_address
# Gmail App Password — generate one at:
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=your_gmail_app_password

# ===== Threads Auto-Post (Meta Graph API) =====
# Threads User ID from your Meta Developer App
THREADS_USER_ID=your_threads_user_id
# Long-lived access token from Meta Developer Platform
THREADS_ACCESS_TOKEN=your_threads_access_token

# ===== Facebook – Hungary Expats Group (Meta Graph API) =====
# Numeric group ID of the "Hungary Expats" Facebook group.
# Open the group in a browser → the number in the URL is the Group ID.
FB_GROUP_ID=your_facebook_group_id
# A long-lived User Access Token with `groups_access_member_info` scope.
# Generate via Meta Developer → Graph API Explorer → select your app → request token.
FB_ACCESS_TOKEN=your_fb_access_token_here
